## Production environment template for Docker Compose.
## Copy to .env and fill your actual provider credentials.

# OTP provider (email and/or mobile)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_char_app_password
SMTP_FROM=your_email@gmail.com
SMTP_USE_TLS=true

# Optional SMS OTP (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
OTP_DEFAULT_COUNTRY_CODE=+91

# Security: disable OTP previews in production.
OTP_ALLOW_PREVIEW=false

# Backup behavior
AGI_DB_BACKUP_ON_START=1
AGI_DB_MAX_BACKUPS=30
